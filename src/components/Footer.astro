---
import { nav, site } from '../data/site';
---
<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <span class="brand-name">{site.name}</span>
      <p class="brand-tagline">{site.tagline}</p>
      <p class="footer-blurb">{site.description}</p>
    </div>

    {nav.filter((i) => i.children).map((col) => (
      <nav class="footer-col" aria-label={col.label}>
        <h3>{col.label}</h3>
        <ul>
          {col.children!.map((c) => (
            <li><a href={c.href}>{c.label}</a></li>
          ))}
        </ul>
      </nav>
    ))}
  </div>

  <div class="container footer-bottom">
    <p>© {new Date().getFullYear()} {site.name}. All rights reserved.</p>
    <a href={site.cta.href} class="footer-cta">{site.cta.label}</a>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-footer-bg);
    color: var(--color-footer-text);
    padding-top: var(--space-section);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr repeat(auto-fit, minmax(160px, 1fr));
    gap: var(--space-8);
    padding-bottom: var(--space-12);
  }
  .footer-brand .brand-name {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    color: #fff;
  }
  .brand-tagline {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: var(--text-xs);
    opacity: 0.7;
    margin-top: var(--space-1);
  }
  .footer-blurb { margin-top: var(--space-4); opacity: 0.75; font-size: var(--text-sm); max-width: 34ch; }
  .footer-col h3 {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #fff;
    margin-bottom: var(--space-4);
  }
  .footer-col ul { list-style: none; padding: 0; display: grid; gap: var(--space-2); }
  .footer-col a { color: var(--color-footer-text); opacity: 0.8; font-size: var(--text-sm); }
  .footer-col a:hover { opacity: 1; color: var(--color-accent); }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    padding-block: var(--space-6);
    border-top: 1px solid rgba(255,255,255,0.12);
    font-size: var(--text-sm);
    opacity: 0.85;
    flex-wrap: wrap;
  }
  .footer-cta {
    color: #fff;
    border: 1px solid rgba(255,255,255,0.35);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-pill);
  }
  .footer-cta:hover { background: var(--color-accent); border-color: var(--color-accent); color: #fff; }
</style>
