---
// Sección grande imagen + texto, con la imagen a sangre (edge-to-edge) que
// llena toda la altura. Inspirada en el bloque "Nuestros pastores": ocupa
// espacio, tipografía grande. Un solo uso por página para no repetir formato.
interface Props {
  id?: string;
  eyebrow?: string;
  heading: string;
  paras: string[];
  image: string;
  imageAlt: string;
  ctaLabel?: string;
  ctaHref?: string;
  reverse?: boolean;
  tone?: 'default' | 'subtle';
}
const {
  id,
  eyebrow,
  heading,
  paras,
  image,
  imageAlt,
  ctaLabel,
  ctaHref,
  reverse = false,
  tone = 'default',
} = Astro.props;
---
<section id={id} class:list={['feature-split', reverse && 'is-reverse', tone === 'subtle' && 'is-subtle']}>
  <figure class="fs-media">
    <img src={image} alt={imageAlt} width="1200" height="1400" loading="lazy" decoding="async" />
  </figure>
  <div class="fs-body">
    <div class="fs-inner">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h2 class="fs-heading">{heading}</h2>
      {paras.map((p) => <p class="fs-text">{p}</p>)}
      {ctaLabel && ctaHref && (
        <a class="fs-cta" href={ctaHref}>
          <span>{ctaLabel}</span>
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 12h15"/><path d="M13 6l6 6-6 6"/></svg>
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .feature-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    min-height: clamp(440px, 46vw, 640px);
    background: var(--color-bg);
    scroll-margin-top: var(--header-height);
  }
  .feature-split.is-subtle { background: var(--color-bg-subtle); }

  .fs-media { margin: 0; overflow: hidden; position: relative; }
  .fs-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.9s var(--ease-out-expo);
  }
  .feature-split:hover .fs-media img { transform: scale(1.045); }
  /* Vignette sutil para dar profundidad al empalme con el texto */
  .fs-media::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    box-shadow: inset 0 0 120px rgba(14, 33, 72, 0.12);
  }
  @media (prefers-reduced-motion: reduce) {
    .feature-split:hover .fs-media img { transform: none; }
  }

  .fs-body { display: flex; align-items: center; }
  .fs-inner {
    max-width: 34rem;
    padding-block: var(--space-12);
    padding-inline: clamp(var(--space-6), 5vw, var(--space-16));
    margin-inline-end: auto;
  }

  /* reverse: imagen a la derecha, texto a la izquierda */
  .is-reverse .fs-media { order: 2; }
  .is-reverse .fs-inner { margin-inline-start: auto; margin-inline-end: 0; }

  .eyebrow { position: relative; display: inline-block; padding-bottom: var(--space-3); }
  .eyebrow::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 40px;
    height: 2px;
    background: var(--color-secondary);
    border-radius: var(--radius-pill);
  }
  .fs-heading {
    font-size: clamp(2.25rem, 1.6rem + 3vw, 3.75rem);
    line-height: 1.05;
    margin-top: var(--space-3);
  }
  .fs-text {
    margin-top: var(--space-4);
    color: var(--color-text);
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
  }
  .fs-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-8);
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: var(--text-sm);
    color: var(--color-heading);
  }
  .fs-cta svg { transition: transform var(--duration-normal) var(--ease-out-expo); }
  .fs-cta:hover { color: var(--color-accent); }
  .fs-cta:hover svg { transform: translateX(6px); }

  @media (max-width: 820px) {
    .feature-split { grid-template-columns: 1fr; }
    .fs-media { height: clamp(280px, 60vw, 420px); order: 0 !important; }
    .fs-inner { padding-block: var(--space-10); max-width: none; }
  }
</style>
