---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PlaceholderForm from '../components/PlaceholderForm.astro';
import { pages } from '../data/pages';

export function getStaticPaths() {
  return pages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
---
<BaseLayout title={page.title} description={page.subtitle ?? page.title}>
  <Hero eyebrow={page.eyebrow} title={page.title} subtitle={page.subtitle} />

  <section class="section">
    <div class="container container--narrow">
      {(page.sections ?? []).map((s) => (
        <div class={`content-block${s.image ? ' has-media' : ''}`}>
          <div class="content-text">
            {s.heading && <h2 id={s.id}>{s.heading}</h2>}
            {(s.paras ?? []).map((p) => <p>{p}</p>)}
            {s.list && (
              <ul class="rule-list">
                {s.list.map((li) => <li>{li}</li>)}
              </ul>
            )}
            {s.links && (
              <ul class="link-cards">
                {s.links.map((l) => (
                  <li>
                    <a href={l.href}>
                      <span class="lc-title">{l.label}</span>
                      {l.body && <span class="lc-body">{l.body}</span>}
                      <span class="lc-arrow">Conocer más →</span>
                    </a>
                  </li>
                ))}
              </ul>
            )}
            {s.quote && <blockquote class="scripture">{s.quote}</blockquote>}
          </div>
          {s.image && (
            <figure class="content-figure">
              <img src={s.image} alt={s.imageAlt ?? ''} loading="lazy" />
              {s.imageCaption && <figcaption>{s.imageCaption}</figcaption>}
            </figure>
          )}
        </div>
      ))}

      {page.type === 'form' && page.fields && <PlaceholderForm fields={page.fields} />}
    </div>
  </section>
</BaseLayout>

<style>
  .content-block + .content-block { margin-top: var(--space-12); }
  .content-block.has-media {
    display: grid;
    grid-template-columns: 1.3fr 0.9fr;
    gap: var(--space-8);
    align-items: start;
  }
  .content-figure { margin: 0; }
  .content-figure img {
    width: 100%;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    object-fit: cover;
  }
  .content-figure figcaption {
    margin-top: var(--space-3);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    color: var(--color-muted);
    text-align: center;
  }
  @media (max-width: 720px) {
    .content-block.has-media { grid-template-columns: 1fr; }
    .content-figure { margin-top: var(--space-6); }
  }
  .content-block h2 {
    scroll-margin-top: calc(var(--header-height) + var(--space-4));
    position: relative;
    padding-bottom: var(--space-3);
  }
  .content-block h2::after {
    content: '';
    position: absolute;
    left: 0; bottom: 0;
    width: 56px; height: 3px;
    background: var(--color-secondary);
    border-radius: var(--radius-pill);
  }
  .content-block p { margin-top: var(--space-4); }
  .rule-list {
    margin-top: var(--space-4);
    padding-left: 0;
    list-style: none;
    display: grid;
    gap: var(--space-3);
  }
  .rule-list li {
    position: relative;
    padding-left: var(--space-8);
  }
  .rule-list li::before {
    content: '✦';
    position: absolute;
    left: 0;
    color: var(--color-secondary);
  }
  .link-cards {
    margin-top: var(--space-6);
    padding-left: 0;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-5);
  }
  .link-cards a {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    transition: transform var(--duration-normal) var(--ease-out-expo), box-shadow var(--duration-normal);
  }
  .link-cards a:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
  .lc-title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    color: var(--color-heading);
  }
  .lc-body {
    margin-top: var(--space-2);
    color: var(--color-muted);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
  }
  .lc-arrow {
    margin-top: var(--space-4);
    font-family: var(--font-display);
    font-weight: var(--weight-medium);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
  }
  .scripture {
    margin-top: var(--space-6);
    padding: var(--space-6) var(--space-8);
    border-left: 4px solid var(--color-accent);
    background: var(--color-bg-subtle);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-style: italic;
    color: var(--color-heading);
    line-height: var(--leading-snug);
  }
</style>
